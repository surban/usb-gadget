# Kernel config snippet enabling USB gadget support for CI testing.
#
# Used with virtme-ng:
#   vng --build --config .ci/usb-gadget.config
#
# This adds dummy_hcd, libcomposite, configfs and all USB gadget function
# drivers needed by the test suite.

CONFIG_CONFIGFS_FS=y
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_GADGET=m
CONFIG_USB_DUMMY_HCD=m
CONFIG_USB_CONFIGFS=m
CONFIG_USB_LIBCOMPOSITE=m
CONFIG_USB_F_FS=m
CONFIG_USB_CONFIGFS_F_FS=y
CONFIG_USB_F_ACM=m
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_F_SERIAL=m
CONFIG_USB_CONFIGFS_SERIAL=y
CONFIG_USB_F_OBEX=m
CONFIG_USB_CONFIGFS_OBEX=y
CONFIG_USB_F_ECM=m
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_F_EEM=m
CONFIG_USB_CONFIGFS_EEM=y
CONFIG_USB_F_NCM=m
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_F_RNDIS=m
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_F_SUBSET=m
CONFIG_USB_CONFIGFS_ECM_SUBSET=y
CONFIG_USB_F_HID=m
CONFIG_USB_CONFIGFS_F_HID=y
CONFIG_USB_F_MASS_STORAGE=m
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_F_PRINTER=m
CONFIG_USB_CONFIGFS_F_PRINTER=y
CONFIG_USB_F_MIDI=m
CONFIG_USB_CONFIGFS_F_MIDI=y
CONFIG_USB_F_UAC2=m
CONFIG_USB_CONFIGFS_F_UAC2=y

# UVC gadget requires the media/video subsystem.
# VIDEO_DEV is only auto-enabled when MEDIA_SUPPORT_FILTER is off
# or one of the MEDIA_*_SUPPORT options is set.
CONFIG_MEDIA_SUPPORT=m
# CONFIG_MEDIA_SUPPORT_FILTER is not set
CONFIG_MEDIA_CAMERA_SUPPORT=y
CONFIG_VIDEO_DEV=m
CONFIG_VIDEOBUF2_CORE=m
CONFIG_VIDEOBUF2_V4L2=m
CONFIG_VIDEOBUF2_VMALLOC=m
CONFIG_VIDEOBUF2_DMA_SG=m
CONFIG_USB_F_UVC=m
CONFIG_USB_CONFIGFS_F_UVC=y